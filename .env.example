# Redis connection (for Docker Compose setup)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=playground

# Exercise mode
# Set to 1 to enable interactive step-by-step mode
STEP_MODE=0

# Set to 1 to use fakeredis (no Docker needed)
LOCAL_MODE=0

# Set to 1 to disable step pause (for automated runs)
NO_PAUSE=1
